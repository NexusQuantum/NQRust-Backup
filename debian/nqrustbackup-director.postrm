#!/bin/sh

set -e


case "$1" in
  purge)
    rm -f  /etc/nqrustbackup/nqrustbackup-dir.conf /etc/nqrustbackup/nqrustbackup-dir.conf.dist
    rm -rf /etc/nqrustbackup/nqrustbackup-dir.d/
    rm -rf /etc/nqrustbackup/nqrustbackup-dir-export/
  ;;
esac


# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
