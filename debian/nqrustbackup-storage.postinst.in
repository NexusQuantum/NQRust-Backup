#!/bin/sh
# postinst script for nqrustbackup
#
# see: dh_installdeb(1)

set -e

# summary of how this script can be called:
#        * <postinst> `configure' <most-recently-configured-version>
#        * <old-postinst> `abort-upgrade' <new version>
#        * <conflictor's-postinst> `abort-remove' `in-favour' <package>
#          <new-version>
#        * <postinst> `abort-remove'
#        * <deconfigured's-postinst> `abort-deconfigure' `in-favour'
#          <failed-install-package> <version> `removing'
#          <conflicting-package> <version>
# for details, see http://www.debian.org/doc/debian-policy/ or
# the debian-policy package

daemon_user=nqrustbackup
daemon_group=nqrustbackup

storage_daemon_user=$daemon_user
storage_daemon_group=$daemon_group

permissions()
{
  chown ${storage_daemon_user}:${daemon_group} /var/lib/nqrustbackup/storage/
  chmod 750 /var/lib/nqrustbackup/storage/
}

scsicrypto()
{
  if [ -f "@confdir@/.enable-cap_sys_rawio" ]; then
    /usr/lib/nqrustbackup/scripts/nqrustbackup-config set_scsicrypto_capabilities
  fi
}

case "$1" in
  configure)
    /usr/lib/nqrustbackup/scripts/nqrustbackup-config deploy_config "nqrustbackup-sd"
    permissions
    /usr/lib/nqrustbackup/scripts/nqrustbackup-config setup_sd_user
    # on Univention distributions the ucr command allows to open the firewall
    if [ -x "/etc/init.d/univention-firewall" ] && which ucr >/dev/null 2>&1; then
      ucr set \
        security/packetfilter/package/nqrustbackup-storage/tcp/@sd_port@/all="ACCEPT" \
        security/packetfilter/package/nqrustbackup-storage/tcp/@sd_port@/all/en="nqrustbackup-sd"
      #invoke-rc.d univention-firewall restart
    fi
    scsicrypto
    ;;

  abort-upgrade | abort-remove | abort-deconfigure) ;;

  *)
    echo "postinst called with unknown argument \`$1'" >&2
    exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
