#! /bin/sh

set -e


case "$1" in
  purge)
    rm -f /etc/nqrustbackup/nqrustbackup-fd.conf /etc/nqrustbackup/nqrustbackup-fd.conf.dist
    rm -rf /etc/nqrustbackup/nqrustbackup-fd.d/
  ;;
esac


# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
