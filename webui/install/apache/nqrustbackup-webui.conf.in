Alias /nqrustbackup-webui <nqrustbackup-webui-dir>/public

<Directory <nqrustbackup-webui-dir>/public>
        Options Indexes FollowSymLinks
        AllowOverride All
        Require all granted

        <IfModule mod_rewrite.c>
            RewriteEngine on
            RewriteBase /nqrustbackup-webui
            RewriteCond %{REQUEST_FILENAME} -s [OR]
            RewriteCond %{REQUEST_FILENAME} -l [OR]
            RewriteCond %{REQUEST_FILENAME} -d
            RewriteRule ^.*$ - [NC,L]
            RewriteRule ^.*$ index.php [NC,L]
        </IfModule>

        <IfModule mod_php7.c>
            php_value include_path ".:<nqrustbackup-webui-dir>"
            php_value upload_max_filesize 10M
            php_value post_max_size 10M
        </IfModule>

        <IfModule mod_php8.c>
            php_value include_path ".:<nqrustbackup-webui-dir>"
            php_value upload_max_filesize 10M
            php_value post_max_size 10M
        </IfModule>
</Directory>
