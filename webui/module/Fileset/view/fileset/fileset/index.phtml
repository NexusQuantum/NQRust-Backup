<script>

   function filesetActionFormatter(value, row) {
      var detailsUrl = '<?php echo $this->url('fileset', array('action' => 'details'), array()); ?>/' + row.filesetid;
      return '<a class="btn btn-default btn-xs" href="' + detailsUrl + '" title="<?php echo $this->translate("Show"); ?>"><span class="glyphicon glyphicon-search" aria-hidden="true"></span></a>';
   }

   $(document).ready(function() {
      setDtTextDomain('<?php echo $this->basePath() . '/js/locale'; ?>');
      setDtLocale('<?php echo $_SESSION['nqrustbackup']['locale']; ?>');

      $('#filesettable').bootstrapTable({
         locale: '<?php echo str_replace('_','-', $_SESSION['nqrustbackup']['locale']); ?>',
         url: '<?php echo $this->url('api/fileset', array(), array()); ?>',
         method: 'get',
         dataType: 'json',
         search: true,
         pagination: true,
         showRefresh: true,
         showColumns: true,
         minimumCountColumns: 2,
         uniqueId: 'filesetid',
         sortName: 'fileset',
         sortOrder: 'asc',
         columns: [
            {
               field: 'filesetid',
               title: '<?php echo $this->translate("Id"); ?>',
               sortable: true,
               width: '90'
            },
            {
               field: 'fileset',
               title: '<?php echo $this->translate("Name"); ?>',
               sortable: true
            },
            {
               field: 'md5',
               title: '<?php echo $this->translate("MD5 checksum"); ?>',
               sortable: true
            },
            {
               field: 'createtime',
               title: '<?php echo $this->translate("Creation time"); ?>',
               sortable: true
            },
            {
               field: 'actions',
               title: '<?php echo $this->translate("Actions"); ?>',
               align: 'center',
               formatter: 'filesetActionFormatter'
            }
         ]
      });
   });

</script>
