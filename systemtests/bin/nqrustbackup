# script to start and stop daemons for individual test

#shellcheck source=../environment.in
. ./environment

CONF_ROOT="$(dirname "${NQRUSTBACKUP_CONFIG_DIR}")/"

for confdir in "${CONF_ROOT}"*; do
  NQRUSTBACKUP_STORAGEDAEMON_BINARY_TO_USE=""
  NQRUSTBACKUP_FILEDAEMON_BINARY_TO_USE=""
  NQRUSTBACKUP_DIRECTOR_BINARY_TO_USE=""
  dir_name="$(basename "${confdir}")"
  daemonsuffix="${dir_name//nqrustbackup/}"
  if [ -d "${confdir}/nqrustbackup-sd.d" ]; then
    # create binary with correct name
    if [ -n "${daemonsuffix}" ]; then
      cp -af "${NQRUSTBACKUP_STORAGEDAEMON_BINARY}" "${NQRUSTBACKUP_STORAGEDAEMON_BINARY}${daemonsuffix}"
    fi
    NQRUSTBACKUP_STORAGEDAEMON_BINARY_TO_USE="${NQRUSTBACKUP_STORAGEDAEMON_BINARY}${daemonsuffix}"
  fi

  if [ -d "${confdir}/nqrustbackup-fd.d" ]; then
    # create binary with correct name
    if [ -n "${daemonsuffix}" ]; then
      cp -af "${NQRUSTBACKUP_FILEDAEMON_BINARY}" "${NQRUSTBACKUP_FILEDAEMON_BINARY}${daemonsuffix}"
    fi
    NQRUSTBACKUP_FILEDAEMON_BINARY_TO_USE="${NQRUSTBACKUP_FILEDAEMON_BINARY}${daemonsuffix}"
  fi

  if [ -d "${confdir}/nqrustbackup-dir.d" ]; then
    # create binary with correct name
    if [ -n "${daemonsuffix}" ]; then
      cp -af "${NQRUSTBACKUP_DIRECTOR_BINARY}" "${NQRUSTBACKUP_DIRECTOR_BINARY}${daemonsuffix}"
    fi
    NQRUSTBACKUP_DIRECTOR_BINARY_TO_USE="${NQRUSTBACKUP_DIRECTOR_BINARY}${daemonsuffix}"
  fi
  NQRUSTBACKUP_STORAGEDAEMON_BINARY="${NQRUSTBACKUP_STORAGEDAEMON_BINARY_TO_USE}" \
  NQRUSTBACKUP_FILEDAEMON_BINARY="${NQRUSTBACKUP_FILEDAEMON_BINARY_TO_USE}" \
  NQRUSTBACKUP_DIRECTOR_BINARY="${NQRUSTBACKUP_DIRECTOR_BINARY_TO_USE}" \
  NQRUSTBACKUP_CONFIG_DIR="${confdir}" "${NQRUSTBACKUP_SCRIPTS_DIR}"/nqrustbackup "$@"
done
