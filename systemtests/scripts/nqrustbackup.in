#! /bin/sh
#
# nqrustbackup       This shell script takes care of starting and stopping
#	       the nqrustbackup daemons.
#
# description: Backup Archiving REcovery Open Sourced.
#
#
export NQRUSTBACKUP_CONFIG_DIR=${NQRUSTBACKUP_CONFIG_DIR:-@confdir@}
NQRUSTBACKUP_SCRIPTS_DIR=${NQRUSTBACKUP_SCRIPTS_DIR:-@scriptdir@}
#
# Disable Glibc malloc checks, it doesn't help and it keeps from getting
#   good dumps
MALLOC_CHECK_=0
export MALLOC_CHECK_

case "$1" in
  start)
    [ -x ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-sd ] && ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-sd $1 $2
    [ -x ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-fd ] && ${NQRUSTBACKUP_CTL_FD_RUNNER:-} ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-fd $1 $2
    [ -x ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-dir ] && ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-dir $1 $2
    ;;

  stop)
    # Stop the FD first so that SD will fail jobs and update catalog
    [ -x ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-fd ] && ${NQRUSTBACKUP_CTL_FD_RUNNER:-} ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-fd $1 $2
    [ -x ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-sd ] && ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-sd $1 $2
    [ -x ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-dir ] && ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-dir $1 $2
    ;;

  restart)
    $0 stop
    sleep 2
    $0 start
    ;;

  status)
    if [ -x ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-dir ] && [ -n "${NQRUSTBACKUP_DIRECTOR_BINARY}" ]; then
      ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-dir status
      status_dir=$?
    fi
    if [ -x ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-sd ] && [ -n "${NQRUSTBACKUP_STORAGEDAEMON_BINARY}" ]; then
      ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-sd status
      status_sd=$?
    fi
    if [ -x ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-fd ] && [ -n "${NQRUSTBACKUP_FILEDAEMON_BINARY}" ]; then
      ${NQRUSTBACKUP_CTL_FD_RUNNER:-} ${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-fd status
      status_fd=$?
    fi
    status_all=$(expr ${status_dir:-0} + ${status_sd:-0} + ${status_fd:-0})
    exit ${status_all}
    ;;

  *)
    echo "Usage: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac
exit 0
