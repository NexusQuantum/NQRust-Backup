#! /bin/bash
#
# nqrustbackup-ctl-sd  This shell script takes care of starting and stopping
#		 the NQRustBackup Storage daemon
#
# description: Backup Archiving REcovery Open Sourced.
#

export PSCMD="@PSCMD@"
export PS="ps"
export AWK="@AWK@"
export PIDOF="@PIDOF@"
export PGREP="@PGREP@"

NQRUSTBACKUP_STORAGEDAEMON_BINARY=${NQRUSTBACKUP_STORAGEDAEMON_BINARY:-@sbindir@/nqrustbackup-sd}
export NQRUSTBACKUP_CONFIG_DIR=${NQRUSTBACKUP_CONFIG_DIR:-@confdir@}
NQRUSTBACKUP_SD_PORT=${NQRUSTBACKUP_SD_PORT:-@sd_port@}
NQRUSTBACKUP_SCRIPTS_DIR=${NQRUSTBACKUP_SCRIPTS_DIR:-@scriptdir@}

#
# Source the generic functions.
#
. "${NQRUSTBACKUP_SCRIPTS_DIR}/nqrustbackup-ctl-funcs"

case "$1" in
  start)
    if [ -x ${NQRUSTBACKUP_STORAGEDAEMON_BINARY} ]; then
      echo "Starting the NQRustBackup Storage daemon"
      OPTIONS=''
      if [ "${NQRUSTBACKUP_CONFIG_DIR}" != '' ]; then
        OPTIONS="${OPTIONS} -c ${NQRUSTBACKUP_CONFIG_DIR}"
      fi

      check_config sd ${NQRUSTBACKUP_STORAGEDAEMON_BINARY} $2 $3 ${OPTIONS} || exit $?
      if [ "x${VALGRIND_SD}" = "x1" ]; then
        valgrind --leak-check=full ${NQRUSTBACKUP_STORAGEDAEMON_BINARY} -v $2 $3 ${OPTIONS}
      else
        ${NQRUSTBACKUP_STORAGEDAEMON_BINARY} -v $2 $3 ${OPTIONS}
      fi
    else
      echo "${NQRUSTBACKUP_STORAGEDAEMON_BINARY} not executable. Did you forget to build?" >&2
      exit 1
    fi
    ;;

  stop)
    if [ -x ${NQRUSTBACKUP_STORAGEDAEMON_BINARY} ]; then
      printf "Stopping the NQRustBackup Storage daemon: "
      shift # shift away the stop
      killproc ${NQRUSTBACKUP_STORAGEDAEMON_BINARY} ${NQRUSTBACKUP_SD_PORT} "${@}"
    else
      echo "${NQRUSTBACKUP_STORAGEDAEMON_BINARY} not executable. Did you forget to build?" >&2
      exit 1
    fi
    ;;

  restart)
    $0 stop
    sleep 5
    $0 start
    ;;

  status)
    [ -x ${NQRUSTBACKUP_STORAGEDAEMON_BINARY} ] && status ${NQRUSTBACKUP_STORAGEDAEMON_BINARY} ${NQRUSTBACKUP_SD_PORT}
    exit $?
    ;;

  *)
    echo "Usage: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac

exit 0
