#
# NQRustBackup User Agent (or Console) Configuration File for PAM Console.
#
# Requires an additional credentials file. Example:
#
# bin/nqrustbackup_console -c etc/nqrustbackup/nqrustbackup_console-pam.conf -p etc/user1.cred
#

Director {
  Name = @basename@-dir
  Port = @dir_port@
  Address = @hostname@
  Password = "a very secure password"
}

Console {
  Name = PamConsole
  Password = "secret"
}
