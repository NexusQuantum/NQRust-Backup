Job {
  Name = "RestoreFiles"
  Description = "Standard Restore template. Only one such job is needed for all standard Jobs/Clients/Storage ..."
  Type = Restore
  Client = nqrustbackup-fd
  FileSet = SelfTest
  Storage = L1
  Pool = Incremental
  Messages = Standard
  Where = @tmp@/nqrustbackup-restores
}
